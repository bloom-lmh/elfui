{
  "name": "elfui-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "description": "ElfUI - compile-time fine-grained reactive Web Components framework.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bloom-lmh/elfui.git"
  },
  "homepage": "https://github.com/bloom-lmh/elfui",
  "bugs": {
    "url": "https://github.com/bloom-lmh/elfui/issues"
  },
  "scripts": {
    "build": "tsc -b packages/shared packages/reactivity packages/runtime packages/compiler-template packages/compiler packages/elfui packages/vite-plugin && node scripts/fix-esm-extensions.mjs",
    "clean": "rimraf --glob \"packages/*/dist\" \"packages/*/tsconfig.tsbuildinfo\" \"coverage\" \"output\"",
    "ci": "pnpm verify",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:template": "pnpm build && node scripts/check-template-types.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "spellcheck": "cspell .",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "node scripts/check-size.mjs",
    "size:report": "node scripts/check-size.mjs --report=output/SIZE-REPORT.md --baseline=docs/SIZE-BASELINE.json",
    "size:baseline": "node scripts/check-size.mjs --write-baseline=docs/SIZE-BASELINE.json --label=v0.1.0-beta.3-m6",
    "benchmark": "npm run build && node --expose-gc scripts/benchmark.mjs --report=output/BENCHMARK.md",
    "benchmark:browser": "npm run build && node scripts/benchmark-browser.mjs --report=output/BROWSER-BENCHMARK.md",
    "benchmark:generated": "npm run build && node scripts/benchmark-generated-code.mjs --report=output/GENERATED-CODE-BENCHMARK.md",
    "benchmark:list": "npm run build && node scripts/benchmark-list.mjs",
    "verify:dist-boundary": "node scripts/check-dist-boundary.mjs",
    "verify:generated-code": "node scripts/benchmark-generated-code.mjs --check",
    "verify:api-boundary": "node scripts/check-api-boundary.mjs",
    "verify:csp-boundary": "node scripts/check-csp-boundary.mjs",
    "verify:ssr-boundary": "node scripts/check-ssr-boundary.mjs",
    "verify:dev-boundary": "node scripts/check-dev-boundary.mjs",
    "gen:public-api": "node scripts/check-public-api.mjs --write",
    "verify:public-api": "node scripts/check-public-api.mjs",
    "verify:light-install": "node scripts/verify-light-install.mjs",
    "verify:browser-smoke": "node scripts/verify-browser-smoke.mjs",
    "verify:browser-matrix": "node scripts/verify-browser-matrix.mjs",
    "verify:external-integrations": "node scripts/verify-external-integrations.mjs",
    "verify:host-integrations": "node scripts/verify-host-integrations.mjs",
    "verify:runtime-copies": "node scripts/verify-runtime-copies.mjs",
    "verify:integrations:chromium": "pnpm verify:external-integrations && pnpm verify:host-integrations && pnpm verify:runtime-copies",
    "verify:publish:artifacts": "node scripts/verify-publish.mjs",
    "verify:publish": "pnpm build && pnpm verify:publish:artifacts",
    "verify:release": "pnpm verify && pnpm verify:integrations:chromium && pnpm verify:publish:artifacts",
    "changeset": "changeset",
    "release:status": "changeset status --output=output/release-status.json",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "gen:tags": "node scripts/generate-tag-types.mjs",
    "verify": "pnpm verify:dist-boundary && pnpm verify:public-api && pnpm verify:api-boundary && pnpm verify:csp-boundary && pnpm format:check && pnpm lint && pnpm spellcheck && pnpm typecheck && pnpm build && pnpm verify:ssr-boundary && pnpm verify:dev-boundary && pnpm verify:generated-code && pnpm test && node scripts/check-template-types.mjs",
    "prepare": "node ./scripts/prepare-husky.mjs"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,scss}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@angular/animations": "22.0.7",
    "@angular/common": "22.0.7",
    "@angular/compiler": "22.0.7",
    "@angular/core": "22.0.7",
    "@angular/platform-browser": "22.0.7",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@eslint/js": "latest",
    "@floating-ui/dom": "1.8.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@types/node": "25.8.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "latest",
    "chart.js": "4.5.1",
    "cspell": "8.19.4",
    "esbuild": "^0.28.0",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "husky": "latest",
    "jsdom": "latest",
    "lint-staged": "latest",
    "lit-html": "3.3.3",
    "playwright-core": "1.61.1",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "^4.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rimraf": "latest",
    "rollup": "4.62.2",
    "rxjs": "7.8.2",
    "solid-js": "1.9.13",
    "svelte": "5.56.6",
    "tslib": "2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "latest",
    "vite": "8.1.5",
    "vitest": "latest",
    "vue": "3.5.40",
    "zone.js": "0.16.2"
  },
  "license": "MIT"
}
