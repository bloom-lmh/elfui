{
  "name": "@elfui/compiler",
  "version": "0.1.0-beta.2",
  "description": "Macro component compiler for ElfUI.",
  "keywords": [
    "elfui",
    "compiler",
    "macro-components",
    "template",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bloom-lmh/elfui.git",
    "directory": "packages/compiler"
  },
  "homepage": "https://github.com/bloom-lmh/elfui/tree/main/packages/compiler",
  "bugs": {
    "url": "https://github.com/bloom-lmh/elfui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compile": {
      "types": "./dist/compile.d.ts",
      "import": "./dist/compile.js"
    },
    "./macro-component": {
      "types": "./dist/macro-component.d.ts",
      "import": "./dist/macro-component.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "README.md",
    "LICENSE",
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.d.ts",
    "dist/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -b && node ../../scripts/fix-esm-extensions.mjs packages/compiler",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elfui/compiler-template": "0.1.0-beta.2",
    "@elfui/reactivity": "0.1.0-beta.2",
    "@elfui/runtime": "0.1.0-beta.2",
    "@elfui/shared": "0.1.0-beta.2",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
