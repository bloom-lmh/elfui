{
  "name": "@elfui/shared",
  "version": "0.1.0-beta.1",
  "description": "Shared utilities for ElfUI.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bloom-lmh/elfui.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/bloom-lmh/elfui/tree/main/packages/shared",
  "bugs": {
    "url": "https://github.com/bloom-lmh/elfui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.d.ts",
    "dist/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -b && node ../../scripts/fix-esm-extensions.mjs packages/shared",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT"
}
