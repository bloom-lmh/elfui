{
  "name": "@elfui/vite-plugin",
  "version": "0.1.0-beta.2",
  "description": "Vite plugin for compiling ElfUI macro components.",
  "keywords": [
    "elfui",
    "vite",
    "vite-plugin",
    "macro-components",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bloom-lmh/elfui.git",
    "directory": "packages/vite-plugin"
  },
  "homepage": "https://github.com/bloom-lmh/elfui/tree/main/packages/vite-plugin",
  "bugs": {
    "url": "https://github.com/bloom-lmh/elfui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "README.md",
    "LICENSE",
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.d.ts",
    "dist/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -b && node ../../scripts/fix-esm-extensions.mjs packages/vite-plugin",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elfui/compiler": "0.1.0-beta.2"
  },
  "license": "MIT"
}
