{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useDefineForClassFields": true,
    "paths": {
      "@elfui/shared": ["./packages/shared/src/index.ts"],
      "@elfui/reactivity": ["./packages/reactivity/src/index.ts"],
      "@elfui/runtime": ["./packages/runtime/src/index.ts"],
      "@elfui/runtime/internal": ["./packages/runtime/src/internal.ts"],
      "@elfui/compiler-template": ["./packages/compiler-template/src/index.ts"],
      "@elfui/compiler": ["./packages/compiler/src/index.ts"],
      "@elfui/vite-plugin": ["./packages/vite-plugin/src/index.ts"],
      "elfui": ["./packages/elfui/src/index.ts"],
      "@elfui/compiler/compile": ["./packages/compiler/src/compile.ts"],
      "@elfui/compiler/macro-component": ["./packages/compiler/src/macro-component.ts"],
      "@elfui/compiler/vite": ["./packages/compiler/src/vite.ts"]
    }
  }
}
